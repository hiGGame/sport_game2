    "/lottery/match/bet-list": {
      "get": {
        "description": "查询可投注的赛事及赔率信息，按发行期号分组。\n支持的玩法编码：6=胜平负，1=让球胜平负，2=总进球，3=比分，4=半全场\n",
        "parameters": [
          {
            "description": "彩种类型。227=足球，228=篮球。不传返回全部",
            "in": "query",
            "name": "lotteryType",
            "schema": {
              "enum": [
                "227",
                "228"
              ],
              "type": "string"
            }
          },
          {
            "description": "玩法筛选。不传返回全部",
