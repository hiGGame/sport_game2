  "info": {
    "description": "微信小程序后端 API，包含：微信授权登录、赛事信息查询、竞猜投注、结算。\n",
    "title": "竞彩赛事竞猜系统",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/customer/login/wechat": {
      "post": {
        "description": "微信小程序登录入口。前端调用 wx.login() 获取 code，后端换取 openid，\n自动注册新用户（赠送 1000 初始积分）或登录已有用户，返回 JWT。\n后续需要鉴权的接口在 Header 中携带 Authorization: Bearer \u003ctoken\u003e。\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "appid": {
                    "description": "微信小程序 AppID（可选，后端已配置默认值）",
                    "type": "string"
                  },
                  "code": {
                    "description": "wx.login() 返回的临时登录凭证，5 分钟有效，仅能使用一次",
                    "type": "string"
                  },
                  "state": {
                    "description": "自定义状态参数，用于防 CSRF（可选）",
                    "type": "string"
                  }
                },
                "required": [
                  "code"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "merchantId": {
                      "description": "商户 ID（预留）",
                      "type": "string"
                    },
                    "needBind": {
                      "description": "是否需要绑定手机号",
                      "type": "boolean"
                    },
                    "openId": {
                      "description": "微信 openid",
                      "type": "string"
                    },
                    "shops": {
                      "description": "关联店铺列表（预留）",
                      "items": {
                        "properties": {
                          "merchantId": {
                            "type": "string"
                          },
                          "shopName": {
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "token": {
                      "description": "JWT 令牌，有效期 7 天",
                      "type": "string"
                    },
                    "wechatAvatar": {
                      "description": "微信头像 URL",
                      "type": "string"
                    },
                    "wechatNickname": {
                      "description": "微信昵称（新用户为空）",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "登录成功"
          }
        },
        "security": [],
        "summary": "微信授权登录",
        "tags": [
          "GameInterface"
        ]
      }
    },
    "/customer/login/official/redirect": {
      "get": {
        "description": "服务号网页授权登录入口（微信内 H5 场景）。\n服务端自动构造微信 OAuth2 授权链接（scope=snsapi_userinfo），\n并通过 302 重定向引导用户进入微信授权页面。\n\n【流程说明】\n1. 前端在微信内 H5 页面中跳转到此接口\n2. 服务端生成随机 state，写入 HttpOnly Cookie（5 分钟有效）\n3. 服务端 302 重定向到微信授权页面\n4. 用户同意授权后，微信回调 /customer/login/official/callback\n\n【前端接入】\n```javascript\nwindow.location.href = '/v1/customer/login/official/redirect';\n```\n\n无需 JWT token。需在配置中设置 wechat.official.appid/secret。\n",
        "responses": {
          "302": {
            "description": "重定向到微信 OAuth2 授权页面",
            "headers": {
              "Location": {
                "description": "微信授权 URL（open.weixin.qq.com/connect/oauth2/authorize）",
                "schema": { "type": "string" }
              }
            }
          },
          "500": {
            "description": "服务号未配置（appid/secret 为空）"
          }
        },
        "security": [],
        "summary": "服务号 OAuth2 授权跳转",
        "tags": ["GameInterface"]
      }
    },
    "/customer/login/official/callback": {
      "get": {
        "description": "微信授权完成后的回调端点。服务端自动完成以下操作：\n1. 校验 state（防 CSRF，与 redirect 端点写入的 Cookie 比对）\n2. 用 code 换取网页 access_token + openid（sns/oauth2/access_token）\n3. 获取用户信息：昵称、头像（sns/userinfo，scope=snsapi_userinfo）\n4. 查找或创建用户（新用户自动写入昵称和头像）\n5. 签发 JWT token\n6. 302 重定向回前端页面，token 通过 URL 参数传递\n\n【前端接入】\n前端无需直接调用此接口。授权完成后微信会自动跳转至此端点，\n服务端处理完毕后会 302 重定向到配置的前端地址（wechat.frontend_url），\n前端页面加载时从 URL 参数读取 token 即可：\n```javascript\nconst token = new URLSearchParams(location.search).get('token');\nif (token) { localStorage.setItem('token', token); }\n```\n\n无需 JWT token。\n",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "微信授权 code（微信自动传入）"
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "状态参数（微信自动传入，与 Cookie 比对校验）"
          }
        ],
        "responses": {
          "302": {
            "description": "重定向回前端页面，携带以下 URL 参数：token, openId, wechatNickname, wechatAvatar, needProfile。错误时重定向到 {frontend_url}?error={错误信息}",
            "headers": {
              "Location": {
                "description": "{frontend_url}?token={JWT}&openId={openid}&wechatNickname={nick}&wechatAvatar={avatar}&needProfile={bool}",
                "schema": { "type": "string" }
              }
            }
          },
          "400": {
            "description": "参数缺失（code/state 为空）或 state 校验失败，重定向到前端并带 error 参数"
          },
          "500": {
            "description": "微信 API 调用失败，重定向到前端并带 error 参数"
          }
        },
        "security": [],
        "summary": "服务号 OAuth2 授权回调",
        "tags": ["GameInterface"]
      }
    },
    "/lottery/bet/create": {
      "post": {
        "description": "用户对一场赛事提交竞猜预测（不消耗骨头）。\n\n【默认值】\n- lotteryType 默认为 \"227\"（竞彩足球）\n- subType 默认为 \"6\"（胜平负）\n- Points 不传或 ≤0 时默认为 2 根骨头（仅记录,不扣减）\n\n【业务规则】\n- 创建竞猜不消耗骨头,不扣减积分\n- 赛事停售或距截止时间不足（60 分钟）返回 403\n- 成功返回预测 ID\n\n需携带 JWT token。\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "betCode": {
                    "description": "投注选项编码。3=胜，1=平，0=负",
                    "type": "string"
                  },
                  "matchId": {
                    "description": "赛事 ID（来自赛事列表）",
                    "type": "string"
                  },
                  "points": {
                    "description": "投注骨头数。不传默认 2（仅记录,不扣减）",
                    "type": "integer"
                  }
                },
                "required": [
                  "matchId",
                  "betCode"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "balanceAfter": {
                      "description": "保留字段,固定返回 0（不再扣减积分）",
                      "type": "integer"
                    },
                    "predictionId": {
                      "description": "竞猜记录 ID",
                      "format": "int64",
                      "type": "integer"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "竞猜创建成功"
          },
          "400": {
            "description": "参数错误（缺少必填字段或玩法选项不匹配）"
          },
          "401": {
            "description": "未登录或 token 无效"
          },
          "403": {
            "description": "赛事已停售或已锁定"
          },
          "404": {
            "description": "赛事未找到"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "summary": "创建竞猜",
        "tags": [
          "GameInterface"
        ]
      }
    },
    "/lottery/bet/mine": {
      "get": {
        "description": "获取当前用户最近的竞猜记录（最多 20 条），含赛事展示信息。\n\n【三角色对比规则】\n- 对于已结算的赛事，返回 winner 字段\n- winner 取值：ai（AI狗猜中）、expert（大拿猜中）、user（用户猜中）、tie（多角色同时猜中）\n- 同时返回 AI狗和大拿的预测及正确性\n\n需携带 JWT token。\n",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "list": {
                      "description": "竞猜记录列表",
                      "items": {
                        "properties": {
                          "aiBetCode": {
                            "description": "AI狗预测",
                            "type": "string"
                          },
                          "aiCorrect": {
                            "description": "AI狗是否正确",
                            "type": "boolean"
                          },
                          "awayTeam": {
                            "description": "客队名",
                            "type": "string"
                          },
                          "betCode": {
                            "description": "投注选项。3=胜 1=平 0=负",
                            "type": "string"
                          },
                          "expertBetCode": {
                            "description": "大拿预测",
                            "type": "string"
                          },
                          "expertCorrect": {
                            "description": "大拿是否正确",
                            "type": "boolean"
                          },
                          "expertName": {
                            "description": "大拿名称",
                            "type": "string"
                          },
                          "homeTeam": {
                            "description": "主队名",
                            "type": "string"
                          },
                          "id": {
                            "description": "记录 ID",
                            "format": "int64",
                            "type": "integer"
                          },
                          "isCorrect": {
                            "description": "是否猜中",
                            "type": "boolean"
                          },
                          "leagueName": {
                            "description": "联赛名",
                            "type": "string"
                          },
                          "matchId": {
                            "description": "赛事 ID",
                            "type": "string"
                          },
                          "matchTime": {
                            "description": "比赛时间",
