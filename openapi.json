    "/matches/{matchId}/predict": {
      "get": {
        "description": "获取指定赛事的三角色预测：\n- AI狗：基于赔率反推概率\n- 资深大拿：平台认证专家推荐\n- 用户竞猜：所有用户对该赛事的竞猜汇总\n已开奖赛事同时返回开奖结果。\n",
        "parameters": [
          {
            "description": "赛事 ID（来自赛事列表的 matchId 字段）",
            "in": "path",
            "name": "matchId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "aiPredictions": {
                      "description": "AI 狗预测",
                      "items": {
                        "$ref": "#/components/schemas/PredictionResult"
                      },
                      "type": "array"
                    },
                    "drawInfo": {
                      "$ref": "#/components/schemas/DrawInfoReply",
                      "description": "开奖结果（仅已开奖赛事返回）"
                    },
                    "expertPredictions": {
                      "description": "资深大拿预测",
                      "items": {
                        "$ref": "#/components/schemas/ExpertPredictionView"
                      },
                      "type": "array"
                    },
                    "matchId": {
                      "description": "赛事 ID",
                      "type": "string"
                    },
                    "matchInfo": {
                      "$ref": "#/components/schemas/MatchBetInfo"
                    },
                    "userPredictions": {
                      "description": "用户竞猜汇总",
                      "items": {
                        "$ref": "#/components/schemas/UserPredictionView"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "成功"
          }
        },
        "security": [],
        "summary": "三角色预测",
        "tags": [
          "GameInterface"
        ]
      }
    },
